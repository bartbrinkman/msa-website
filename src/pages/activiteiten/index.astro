---
import Base from '../../layouts/Base.astro';
import { asset } from '../../utils';
---

<Base title="Activiteiten">
  <div class="bg-gradient-to-r from-primary-dark to-primary text-white py-12">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-medium font-heading uppercase tracking-normal">Activiteiten</h1>
      <p class="mt-3 text-white/80">Wat wij doen — wekelijks, jaarlijks en alles daartussenin.</p>
    </div>
  </div>


  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="grid md:grid-cols-2 gap-6">

      <a href={asset("/activiteiten/clubavonden")} class="group block border border-gray-200 rounded-lg p-6 hover:shadow-lg hover:border-primary/30 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded font-medium">Wekelijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary group-hover:text-primary-light transition-colors">Clubavonden</h2>
        <p class="text-gray-600 text-sm mt-1">Iedere donderdagavond werken wij aan onze banen. Kom gerust een keer langs.</p>
        <div class="mt-3 text-sm text-primary-light font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Meer lezen &rarr;
        </div>
      </a>

      <a href={asset("/activiteiten/modelspoordagen")} class="group block border border-gray-200 rounded-lg p-6 hover:shadow-lg hover:border-primary/30 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-accent/10 text-accent px-2 py-0.5 rounded font-medium">Jaarlijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary group-hover:text-primary-light transition-colors">Noord-Hollandse Modelspoordagen</h2>
        <p class="text-gray-600 text-sm mt-1">Ons grote jaarlijkse publieksevenement samen met andere clubs uit de regio.</p>
        <div class="mt-3 text-sm text-primary-light font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Meer lezen &rarr;
        </div>
      </a>

      <a href={asset("/activiteiten/darmstadt")} class="group block border border-gray-200 rounded-lg p-6 hover:shadow-lg hover:border-primary/30 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-amber-50 text-amber-800 px-2 py-0.5 rounded font-medium">Jaarlijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary group-hover:text-primary-light transition-colors">Excursie Darmstadt</h2>
        <p class="text-gray-600 text-sm mt-1">Jaarlijks bezoek aan het Eisenbahnmuseum in Darmstadt, waar wij ook een baan exposeren.</p>
        <div class="mt-3 text-sm text-primary-light font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Meer lezen &rarr;
        </div>
      </a>

      <div class="group block border border-gray-200 rounded-lg p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-accent/10 text-accent px-2 py-0.5 rounded font-medium">Jaarlijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary">Open Dag &amp; Open Monumentendag</h2>
        <p class="text-gray-600 text-sm mt-1">Jaarlijkse open dag en deelname aan Open Monumentendag. Alle banen te bezichtigen voor publiek.</p>
      </div>

      <div class="group block border border-gray-200 rounded-lg p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-amber-50 text-amber-800 px-2 py-0.5 rounded font-medium">Jaarlijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary">Ruilbeurs</h2>
        <p class="text-gray-600 text-sm mt-1">Modelspoorbeurs waar liefhebbers materiaal kunnen kopen, verkopen en ruilen.</p>
      </div>

      <div class="group block border border-gray-200 rounded-lg p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded font-medium">Maandelijks</span>
        </div>
        <h2 class="text-lg font-semibold text-primary">Huider</h2>
        <p class="text-gray-600 text-sm mt-1">Iedere tweede zaterdag van de maand.</p>
      </div>

    </div>

    <div class="mt-8 p-6 bg-warm rounded-lg">
      <p class="text-gray-700">
        Bekijk de <a href={asset("/agenda")} class="text-primary-light underline font-medium">agenda</a> voor aankomende data.
      </p>
    </div>
  </div>
</Base>
