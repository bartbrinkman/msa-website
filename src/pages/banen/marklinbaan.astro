---
import Page from '../../layouts/Page.astro';
import Carousel from '../../components/Carousel.astro';

const images = [
  { src: '/images/marklinbaan/marklin_1station.jpg', title: 'Het station' },
  { src: '/images/marklinbaan/marklin_2tunnels.jpg', title: 'De tunnels' },
  { src: '/images/marklinbaan/marklin_3brug.jpg', title: 'De verkeersbrug', description: 'Compleet met rijdende auto\'s' },
  { src: '/images/marklinbaan/marklin_4huizen.jpg', title: 'Bebouwing rondom het station' },
  { src: '/images/marklinbaan/marklin_5kerk.jpg', title: 'Kerk op de heuvel' },
  { src: '/images/marklinbaan/marklin_6schaduwstation.jpg', title: 'Het schaduwstation' },
];
---

<Page title="Marklinbaan" hero="Marklinbaan" heroImage="/images/marklinbaan/marklin_1station.jpg">
  <p><strong>Schaal:</strong> H0 (1:87) | <strong>Systeem:</strong> Marklin 3-rail AC | <strong>Besturing:</strong> iTrain</p>

  <h2>Het verhaal</h2>
  <p>
    De Marklinbaan is een fictieve baan met drie rechthoekige lusconfiguraties
    die aan de voorzijde samenkomen. Het is een levendige baan vol details en
    beweging.
  </p>

  <Carousel images={images} id="marklinbaan" />

  <h2>Bijzondere kenmerken</h2>
  <ul>
    <li>Bergen, tunnels en een kerk op een heuvel</li>
    <li>Rijdende auto's en bewegende figuren (fietsers, rijschool, snelweg)</li>
    <li>Miniatuurfiguur "Bertje Doperwtje"</li>
    <li>3 tot 4 verborgen schaduwstations met elk meerdere treincapaciteit</li>
    <li>Besturing via iTrain met 15+ locomotieven</li>
    <li>Kabelbaan en verbeterde scenery</li>
  </ul>
</Page>
