---
import Page from '../../layouts/Page.astro';
import Carousel from '../../components/Carousel.astro';
import carousels from '../../content/carousels.json';

const images = carousels.märklinbaan;
---

<Page title="Märklinbaan" hero="Märklinbaan" heroImage="/images/märklinbaan/märklin_1station.jpg">
  <p><strong>Schaal:</strong> H0 (1:87) | <strong>Systeem:</strong> 3-rail AC | <strong>Besturing:</strong> iTrain</p>

  <h2>Het verhaal</h2>
  <p>
    De Märklinbaan is een fictieve baan met drie rechthoekige lusconfiguraties
    die aan de voorzijde samenkomen. Het is een levendige baan vol details en
    beweging.
  </p>

  <Carousel images={images} id="märklinbaan" />

  <h2>Bijzondere kenmerken</h2>
  <ul>
    <li>Bergen, tunnels en een kerk op een heuvel</li>
    <li>Rijdende auto's en bewegende figuren (fietsers, rijschool, snelweg)</li>
    <li>Miniatuurfiguur "Bertje Doperwtje"</li>
    <li>3 tot 4 verborgen schaduwstations met elk meerdere treincapaciteit</li>
    <li>Besturing via iTrain met 15+ locomotieven</li>
    <li>Kabelbaan en verbeterde scenery</li>
  </ul>

  <h2>Lopende projecten</h2>
  <ul>
    <li>Uitbreiding van de autobaan</li>
    <li>Vernieuwing van de verlichting</li>
    <li>Verdere uitwerking van de stad</li>
  </ul>
</Page>
